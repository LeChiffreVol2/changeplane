# GitHub App client credentials. The App may be installed on GitHub.com personal accounts
# and organizations. Request repository Contents, Pull requests, Workflows, and Actions Secrets
# write permissions plus Checks read. Leave GITHUB_APP_SLUG unset only for a deliberate local
# broad-OAuth observe fallback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=

# Enables public repository-scoped onboarding. Exact test + BYOK are still required before an
# autonomous setup PR can be created. Set false to close new installations without disabling replay.
CHANGEPLANE_SELF_SERVE_ENABLED=true

# Generate at least 32 random characters. Rotating this invalidates every web session.
CHANGEPLANE_SESSION_SECRET=

# Exact HTTPS origin without a path, query, or trailing slash.
CHANGEPLANE_APP_ORIGIN=https://changeplane.example.com

# Exact target for controlled-canary mode only. Self-serve mode verifies each App installation.
CHANGEPLANE_CANARY_REPOSITORY=your-user/changeplane-disposable-canary

# Dedicated repair controller. In controlled-canary mode the repair repository must equal the
# canary exactly. In self-serve mode repository authority comes from the verified App installation.
# Keep the global switch false until the disposable release canary passes.
CHANGEPLANE_REPAIR_REPOSITORY=your-user/changeplane-disposable-canary
CHANGEPLANE_REPAIR_ENABLED=false
CHANGEPLANE_REPAIR_GENERATION=1

# Dedicated GitHub App publisher credentials. The App ID and private key must belong to
# GITHUB_APP_SLUG and its repository-scoped installation. Keep the PEM server-side only.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Independent 32+ character server master secret. Never copy this value into GitHub.
# The repository receives only a repository-bound derived HMAC as an Actions Secret.
CHANGEPLANE_CONTROLLER_SECRET=

# Private managed-execution canary only. Keep this server-side; never copy it into a customer repository.
CHANGEPLANE_MANAGED_OPENAI_API_KEY=

# Structured metadata only; request bodies, tokens, and provider keys are never logged.
CHANGEPLANE_LOG_REQUESTS=true
