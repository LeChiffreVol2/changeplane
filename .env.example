# GitHub App client credentials. Leave GITHUB_APP_SLUG unset only for the broad OAuth observe fallback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=

# Generate at least 32 random characters. Rotating this invalidates every web session.
CHANGEPLANE_SESSION_SECRET=

# Exact HTTPS origin without a path, query, or trailing slash.
CHANGEPLANE_APP_ORIGIN=https://changeplane.example.com

# Optional controlled-rollout guard. When set, every repository route is restricted to this exact target.
CHANGEPLANE_CANARY_REPOSITORY=your-user/changeplane-disposable-canary

# Dedicated repair controller. Keep both switches false until every live canary gate passes.
# The repair repository must equal CHANGEPLANE_CANARY_REPOSITORY exactly.
CHANGEPLANE_REPAIR_REPOSITORY=your-user/changeplane-disposable-canary
CHANGEPLANE_REPAIR_ENABLED=false
CHANGEPLANE_REPAIR_GENERATION=1

# Dedicated GitHub App publisher credentials. The App ID and private key must belong to
# GITHUB_APP_SLUG and its repository-scoped installation. Keep the PEM server-side only.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Independent 32+ character server master secret. Never copy this value into GitHub.
# The repository receives only a repository-bound derived HMAC as an Actions Secret.
CHANGEPLANE_CONTROLLER_SECRET=

# Private Managed pilot only. Keep this server-side; never copy it into a customer repository.
CHANGEPLANE_MANAGED_DEEPSEEK_API_KEY=

# Structured metadata only; request bodies, tokens, and provider keys are never logged.
CHANGEPLANE_LOG_REQUESTS=true
