{
  "name": "changeplane",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test --test-concurrency=1 src/lib/*.test.js action/*.test.js tests/*.test.js",
    "test:e2e": "npm run build && playwright test",
    "verify": "npm test && npm run build && npm run audit:public",
    "audit:public": "node scripts/audit-public-data.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=22.18 <23"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "libsodium-wrappers": "^0.8.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
